{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract", "existingSecrets", "ingress", "network", "images", "resources"],
  "properties": {
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["renderOnly", "productionApproved"],
      "properties": {
        "renderOnly": {"const": true},
        "productionApproved": {"const": false}
      }
    },
    "existingSecrets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bff", "api", "scanner", "promotion", "deletion"],
      "properties": {
        "bff": {"$ref": "#/definitions/secretName"},
        "api": {"$ref": "#/definitions/secretName"},
        "scanner": {"$ref": "#/definitions/secretName"},
        "promotion": {"$ref": "#/definitions/secretName"},
        "deletion": {"$ref": "#/definitions/secretName"}
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["className", "host"],
      "properties": {
        "className": {"type": "string", "minLength": 1, "not": {"const": "CHANGE_ME_INGRESS_CLASS"}},
        "host": {"type": "string", "pattern": "^[a-z0-9.-]+$", "not": {"const": "CHANGE_ME_EXAMPLE_INVALID"}}
      }
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identityCidr", "databaseCidr", "objectStorageCidr", "scannerCidr"],
      "properties": {
        "identityCidr": {"$ref": "#/definitions/cidr"},
        "databaseCidr": {"$ref": "#/definitions/cidr"},
        "objectStorageCidr": {"$ref": "#/definitions/cidr"},
        "scannerCidr": {"$ref": "#/definitions/cidr"}
      }
    },
    "images": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bff", "api", "scanner", "promotion", "deletion"],
      "properties": {
        "bff": {"$ref": "#/definitions/image"},
        "api": {"$ref": "#/definitions/image"},
        "scanner": {"$ref": "#/definitions/image"},
        "promotion": {"$ref": "#/definitions/image"},
        "deletion": {"$ref": "#/definitions/image"}
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requests", "limits"],
      "properties": {
        "requests": {"$ref": "#/definitions/resourcePair"},
        "limits": {"$ref": "#/definitions/resourcePair"}
      }
    }
  },
  "definitions": {
    "secretName": {"type": "string", "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$", "not": {"pattern": "^CHANGE_ME"}},
    "cidr": {"type": "string", "pattern": "^[0-9a-fA-F:.]+/[0-9]{1,3}$"},
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "digest"],
      "properties": {
        "repository": {"type": "string", "pattern": "^[a-zA-Z0-9._/-]+$", "not": {"pattern": ":latest$"}},
        "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
      }
    },
    "resourcePair": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cpu", "memory"],
      "properties": {
        "cpu": {"type": "string", "minLength": 1},
        "memory": {"type": "string", "minLength": 1}
      }
    }
  }
}

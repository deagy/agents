    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "jsdom": "29.1.1",
    "npm": "12.0.1",
    "typescript": "6.0.3",
    "vite": "8.1.5",

    {"id": "G9", "name": "Deployment Authorization", "phase": "deployment-authorization", "author_agents": [], "tasks": ["authorize-deployment"], "artifacts": ["deployment-authorization-record"], "human_authorities": ["release_authority"], "human_only": true},

{
  "version": 1,
  "gates": [
    {"id": "G1", "name": "Intent", "phase": "intent", "author_agents": ["product-intent-agent"], "human_authorities": ["product_owner"]},
    {"id": "G2", "name": "Requirements Baseline", "phase": "requirements", "author_agents": ["requirements-agent"], "human_authorities": ["product_owner", "engineering_lead"]},
    {"id": "G3", "name": "Architecture", "phase": "architecture", "author_agents": ["cloud-architect"], "human_authorities": ["system_architect"]},
    {"id": "G4", "name": "Governance and Data", "phase": "governance-data", "author_agents": ["governance-planner", "data-governance-engineer"], "review_agents": ["compliance-reviewer"], "human_authorities": ["governance_lead"], "conditional_human_authorities": ["data_control_owner"]},
    {"id": "G5", "name": "Security and Crypto", "phase": "security-crypto", "author_agents": ["threat-modeler", "cryptographic-assurance-engineer"], "review_agents": ["security-reviewer"], "human_authorities": ["security_lead"], "conditional_human_authorities": ["human_key_owner"]},
    {"id": "G6", "name": "Verification and Test", "phase": "verify", "author_agents": ["application-engineer"], "review_agents": ["test-engineer"], "human_authorities": ["engineering_lead"], "conditional_human_authorities": ["uat_product_owner"]},
    {"id": "G7", "name": "Evidence", "phase": "evidence", "author_agents": ["evidence-curator"], "review_agents": ["compliance-reviewer"], "human_authorities": ["release_owner"]},
    {"id": "G8", "name": "Release Readiness", "phase": "release-readiness", "author_agents": ["release-engineer"], "human_authorities": ["release_owner"]},
    {"id": "G9", "name": "Deployment Authorization", "phase": "deployment-authorization", "author_agents": [], "human_authorities": ["release_authority"], "human_only": true},
    {"id": "G10", "name": "Runtime Conformance", "phase": "runtime-conformance", "author_agents": ["observability-sre"], "human_authorities": ["service_owner"], "conditional_human_authorities": ["implicated_security_lead", "implicated_governance_lead"]}
  ],
  "rules": {
    "approval_default": "pending",
    "unknown_blocks": true,
    "author_cannot_review_or_approve_same_revision": true,
    "material_change_invalidates_downstream": true
  }
}

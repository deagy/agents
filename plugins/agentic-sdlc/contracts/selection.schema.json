{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Portable Agentic SDLC dispatch plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task_id", "dispatch_fingerprint", "generated_at", "status", "workflow", "inputs", "matched_routes", "matched_risks", "agents", "required_quality_gates", "human_gates", "knowledge_context"],
  "properties": {
    "schema_version": {"const": 2},
    "task_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"},
    "dispatch_fingerprint": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "generated_at": {"type": "string", "format": "date-time"},
    "status": {"enum": ["ready", "needs-triage"]},
    "workflow": {"enum": ["product-intake", "new-service", "runtime-assurance", "support-escalation", "production-release", "debugging", "infrastructure-change", "pipeline-change", "needs-triage"]},
    "inputs": {"type": "object"},
    "matched_routes": {"type": "array", "items": {"type": "string"}},
    "matched_risks": {"type": "array", "items": {"type": "object"}},
    "agents": {"type": "object", "additionalProperties": false, "required": ["primary", "reviewers", "support"], "properties": {"primary": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}, "reviewers": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}, "support": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}}},
    "required_quality_gates": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["id", "required", "reason", "contributing_routes"], "properties": {"id": {"enum": ["G1", "G2", "G3", "G4", "G5", "G6", "G7", "G8", "G9", "G10"]}, "required": {"const": true}, "reason": {"type": "string", "minLength": 1}, "contributing_routes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}}}},
    "human_gates": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["id", "required", "reason"], "properties": {"id": {"type": "string", "minLength": 1}, "required": {"const": true}, "reason": {"type": "string", "minLength": 1}}}},
    "knowledge_context": {"type": "object"}
  }
}

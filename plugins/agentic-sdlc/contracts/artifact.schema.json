{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agentic SDLC traceable artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_id", "revision", "kind", "authors", "verifiers", "upstream_ids", "downstream_ids", "provenance", "evidence"],
  "properties": {
    "artifact_id": {"type": "string", "minLength": 1},
    "revision": {"type": "string", "minLength": 1},
    "kind": {"type": "string", "minLength": 1},
    "authors": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "verifiers": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "upstream_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "downstream_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "provenance": {"type": "object", "required": ["created_at", "ai_generated"], "properties": {"created_at": {"type": "string", "format": "date-time"}, "ai_generated": {"type": "boolean"}}},
    "evidence": {"type": "array", "items": {"type": "object"}}
  }
}

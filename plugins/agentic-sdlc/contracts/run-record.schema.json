{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Portable authoritative Agentic SDLC run record",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "task_id", "dispatch_fingerprint", "recorded_at", "classification", "mode", "baseline_revision", "scope", "disposition", "intent_record_id", "requirements_baseline_id", "current_lifecycle_phase", "knowledge_retrieval", "impact_profile", "lifecycle_gates", "specialist_attestations", "re_entry_history", "execution_summary"],
  "properties": {
    "version": {"const": 2},
    "task_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"},
    "dispatch_fingerprint": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "recorded_at": {"type": "string", "format": "date-time"},
    "classification": {"$ref": "#/$defs/nonEmpty"},
    "mode": {"$ref": "#/$defs/nonEmpty"},
    "baseline_revision": {"$ref": "#/$defs/nonEmpty"},
    "scope": {"$ref": "#/$defs/nonEmpty"},
    "disposition": {"$ref": "#/$defs/nonEmpty"},
    "intent_record_id": {"type": ["string", "null"]},
    "requirements_baseline_id": {"type": ["string", "null"]},
    "current_lifecycle_phase": {"enum": ["intent", "requirements", "architecture", "governance-data", "security-crypto", "build", "verify", "evidence", "release-readiness", "deployment-authorization", "runtime-conformance", "feedback"]},
    "knowledge_retrieval": {"$ref": "#/$defs/knowledge"},
    "impact_profile": {"$ref": "#/$defs/impactProfile"},
    "lifecycle_gates": {"type": "array", "minItems": 10, "maxItems": 10, "items": {"$ref": "#/$defs/gate"}},
    "specialist_attestations": {"type": "array", "items": {"$ref": "#/$defs/gate"}},
    "re_entry_history": {"type": "array", "items": {"$ref": "#/$defs/invalidation"}},
    "execution_summary": {"type": "object", "additionalProperties": false, "required": ["gates"], "properties": {"gates": {"type": "object", "minProperties": 10, "maxProperties": 10, "additionalProperties": false, "patternProperties": {"^G(?:[1-9]|10)$": {"type": "object", "additionalProperties": false, "required": ["configured", "ignored", "ignore_reason", "required_agents", "dispatched_agents", "required_tasks", "completed_tasks", "required_agent_artifacts", "produced_agent_artifacts"], "properties": {"configured": {"type": "boolean"}, "ignored": {"type": "boolean"}, "ignore_reason": {"type": ["string", "null"]}, "required_agents": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}}, "dispatched_agents": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}}, "required_tasks": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}}, "completed_tasks": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}}, "required_agent_artifacts": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["agent_id", "artifact_id"], "properties": {"agent_id": {"$ref": "#/$defs/nonEmpty"}, "artifact_id": {"$ref": "#/$defs/nonEmpty"}}}}, "produced_agent_artifacts": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["agent_id", "artifact_id", "revision", "digest"], "properties": {"agent_id": {"$ref": "#/$defs/nonEmpty"}, "artifact_id": {"$ref": "#/$defs/nonEmpty"}, "revision": {"$ref": "#/$defs/nonEmpty"}, "digest": {"$ref": "#/$defs/nonEmpty"}}}}}}}}}}
  },
  "$defs": {
    "nonEmpty": {"type": "string", "minLength": 1},
    "identity": {"type": "object", "additionalProperties": false, "required": ["id", "role", "kind"], "properties": {"id": {"$ref": "#/$defs/nonEmpty"}, "role": {"$ref": "#/$defs/nonEmpty"}, "kind": {"enum": ["human", "agent", "service"]}}},
    "evidence": {"type": "object", "additionalProperties": false, "required": ["evidence_id", "uri", "hash_algorithm", "hash", "classification"], "properties": {"evidence_id": {"$ref": "#/$defs/nonEmpty"}, "uri": {"$ref": "#/$defs/nonEmpty"}, "hash_algorithm": {"$ref": "#/$defs/nonEmpty"}, "hash": {"$ref": "#/$defs/nonEmpty"}, "classification": {"$ref": "#/$defs/nonEmpty"}}},
    "knowledge": {"type": "object", "additionalProperties": false, "required": ["status", "reason", "query_ids", "evidence_refs", "influence"], "properties": {"status": {"enum": ["complete", "unavailable", "empty", "unauthorized", "not-applicable"]}, "reason": {"type": ["string", "null"]}, "query_ids": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}}, "evidence_refs": {"type": "array", "items": {"$ref": "#/$defs/evidence"}}, "influence": {"$ref": "#/$defs/nonEmpty"}}},
    "artifactBinding": {"type": "object", "additionalProperties": false, "required": ["artifact_id", "revision", "digest"], "properties": {"artifact_id": {"$ref": "#/$defs/nonEmpty"}, "revision": {"$ref": "#/$defs/nonEmpty"}, "digest": {"$ref": "#/$defs/nonEmpty"}, "environment": {"type": ["string", "null"]}}},
    "authorityRequirement": {"type": "object", "additionalProperties": false, "required": ["authority_id", "authority_type", "role", "applicability", "rationale"], "properties": {"authority_id": {"$ref": "#/$defs/nonEmpty"}, "authority_type": {"enum": ["independent-verifier", "human-approver"]}, "role": {"$ref": "#/$defs/nonEmpty"}, "applicability": {"enum": ["applicable", "not-applicable", "unknown"]}, "rationale": {"type": ["string", "null"]}}},
    "approval": {"type": "object", "additionalProperties": false, "required": ["status", "approver", "decided_at", "evidence_refs"], "properties": {"status": {"enum": ["pending", "approved", "rejected", "not-required"]}, "approver": {"anyOf": [{"$ref": "#/$defs/identity"}, {"type": "null"}]}, "decided_at": {"type": ["string", "null"], "format": "date-time"}, "evidence_refs": {"type": "array", "items": {"$ref": "#/$defs/evidence"}}}},
    "finding": {"type": "object", "additionalProperties": false, "required": ["finding_id", "severity", "status", "owner"], "properties": {"finding_id": {"$ref": "#/$defs/nonEmpty"}, "severity": {"enum": ["critical", "high", "medium", "low", "informational"]}, "status": {"enum": ["open", "resolved", "accepted-exception"]}, "owner": {"$ref": "#/$defs/nonEmpty"}}},
    "exception": {"type": "object", "additionalProperties": false, "required": ["exception_id", "finding_id", "justification", "compensating_controls", "owner", "approver", "expires_at", "remediation_plan"], "properties": {"exception_id": {"$ref": "#/$defs/nonEmpty"}, "finding_id": {"$ref": "#/$defs/nonEmpty"}, "justification": {"$ref": "#/$defs/nonEmpty"}, "compensating_controls": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/nonEmpty"}}, "owner": {"$ref": "#/$defs/identity"}, "approver": {"$ref": "#/$defs/identity"}, "expires_at": {"type": "string", "format": "date-time"}, "remediation_plan": {"$ref": "#/$defs/nonEmpty"}}},
    "invalidation": {"type": "object", "additionalProperties": false, "required": ["invalidated_at", "actor", "reason", "earliest_gate", "invalidated_gate_ids", "affected_artifact_bindings", "superseding_artifact_id"], "properties": {"invalidated_at": {"type": "string", "format": "date-time"}, "actor": {"$ref": "#/$defs/nonEmpty"}, "reason": {"$ref": "#/$defs/nonEmpty"}, "earliest_gate": {"enum": ["G1", "G2", "G3", "G4", "G5", "G6", "G7", "G8", "G9", "G10"]}, "invalidated_gate_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["G1", "G2", "G3", "G4", "G5", "G6", "G7", "G8", "G9", "G10"]}}, "affected_artifact_bindings": {"type": "array", "items": {"$ref": "#/$defs/artifactBinding"}}, "superseding_artifact_id": {"type": ["string", "null"]}}},
    "gate": {"type": "object", "additionalProperties": false, "required": ["tier", "gate_id", "name", "applicability", "applicability_rationale", "status", "artifact_bindings", "preparers", "independent_verifier", "independence_declaration", "authority_requirements", "human_approvals", "decided_at", "evidence_refs", "knowledge_status", "findings", "exceptions", "invalidation_history", "required_reentry_gate"], "properties": {"tier": {"enum": ["lifecycle", "specialist"]}, "gate_id": {"$ref": "#/$defs/nonEmpty"}, "name": {"$ref": "#/$defs/nonEmpty"}, "applicability": {"enum": ["applicable", "not-applicable", "unknown"]}, "applicability_rationale": {"type": ["string", "null"]}, "status": {"enum": ["pending", "ready", "approved", "request-changes", "needs-information", "blocked", "invalidated"]}, "artifact_bindings": {"type": "array", "items": {"$ref": "#/$defs/artifactBinding"}}, "preparers": {"type": "array", "items": {"$ref": "#/$defs/identity"}}, "independent_verifier": {"anyOf": [{"$ref": "#/$defs/identity"}, {"type": "null"}]}, "independence_declaration": {"type": "object", "additionalProperties": false, "required": ["verifier_confirmed_not_preparer", "verifier_made_material_correction"], "properties": {"verifier_confirmed_not_preparer": {"type": "boolean"}, "verifier_made_material_correction": {"const": false}}}, "authority_requirements": {"type": "array", "items": {"$ref": "#/$defs/authorityRequirement"}}, "human_approvals": {"type": "array", "items": {"$ref": "#/$defs/approval"}}, "decided_at": {"type": ["string", "null"], "format": "date-time"}, "evidence_refs": {"type": "array", "items": {"$ref": "#/$defs/evidence"}}, "knowledge_status": {"enum": ["complete", "unavailable", "empty", "unauthorized", "not-applicable"]}, "findings": {"type": "array", "items": {"$ref": "#/$defs/finding"}}, "exceptions": {"type": "array", "items": {"$ref": "#/$defs/exception"}}, "invalidation_history": {"type": "array", "items": {"$ref": "#/$defs/invalidation"}}, "required_reentry_gate": {"type": ["string", "null"], "enum": [null, "G1", "G2", "G3", "G4", "G5", "G6", "G7", "G8", "G9", "G10"]}}},
    "impactItem": {"type": "object", "additionalProperties": false, "required": ["id", "extension", "applicability", "definition_reference", "rationale", "owner", "evidence_refs"], "properties": {"id": {"$ref": "#/$defs/nonEmpty"}, "extension": {"$ref": "#/$defs/nonEmpty"}, "applicability": {"enum": ["applicable", "not-applicable", "unknown"]}, "definition_reference": {"type": ["string", "null"]}, "rationale": {"type": ["string", "null"]}, "owner": {"type": ["string", "null"]}, "evidence_refs": {"type": "array", "items": {"$ref": "#/$defs/evidence"}}}},
    "impactProfile": {"type": "object", "additionalProperties": false, "required": ["profile_id", "status", "impact_categories", "specialized_boms", "blocking_unknowns"], "properties": {"profile_id": {"$ref": "#/$defs/nonEmpty"}, "status": {"enum": ["draft", "blocked", "complete"]}, "impact_categories": {"type": "array", "items": {"$ref": "#/$defs/impactItem"}}, "specialized_boms": {"type": "array", "items": {"$ref": "#/$defs/impactItem"}}, "blocking_unknowns": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}}}}
  }
}

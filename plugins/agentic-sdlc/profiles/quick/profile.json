{
  "id": "quick",
  "description": "Low-ceremony default for informational work; implementation and change work first requires product intent and requirements (G1/G2). Mutation gates (production, destructive, persistent migration, privileged identity, risk acceptance) always still apply regardless of profile.",
  "agents": ["application-engineer", "frontend-engineer", "backend-engineer", "test-engineer", "code-reviewer", "debugging-engineer", "security-reviewer", "release-engineer", "product-intent-agent", "requirements-agent"],
  "change_intake": {
    "keywords": ["implement", "create", "new feature", "new service", "add feature", "build", "change", "update", "modify", "refactor", "fix", "repair", "remove", "delete", "migrate", "introduce", "enhance", "extend", "replace", "upgrade", "rework"],
    "agents": ["product-intent-agent", "requirements-agent"],
    "quality_gates": ["G1", "G2"]
  },
  "routing": [
    {"id": "build", "phrases": ["implement", "add feature", "build", "change behavior", "update code"], "agents": ["application-engineer"], "reviewers": ["code-reviewer", "test-engineer"]},
    {"id": "frontend", "phrases": ["frontend component", "user interface", "react", "browser behavior"], "agents": ["frontend-engineer"], "reviewers": ["code-reviewer", "test-engineer"]},
    {"id": "backend", "phrases": ["backend api", "http api", "server behavior", "database query"], "agents": ["backend-engineer"], "reviewers": ["code-reviewer", "test-engineer"]},
    {"id": "debugging", "phrases": ["bug", "error", "crash", "failing test", "stack trace", "reproduce"], "agents": ["debugging-engineer"], "reviewers": ["test-engineer"]},
    {"id": "review", "phrases": ["review this", "code review", "review the change"], "agents": ["code-reviewer"], "reviewers": ["test-engineer"]},
    {"id": "release", "phrases": ["prepare release", "cut a release", "ship this"], "agents": ["release-engineer"], "reviewers": ["security-reviewer", "code-reviewer"]}
  ],
  "impact_categories": []
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/agent-selection.schema.json",
  "title": "Local Agent Selection Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task_id", "dispatch_fingerprint", "generated_at", "status", "workflow", "inputs", "matched_routes", "matched_risks", "agents", "required_quality_gates", "ignored_quality_gates", "gate_dispatch", "human_gates", "knowledge_context"],
  "properties": {
    "schema_version": { "const": 2 },
    "task_id": { "type": "string", "minLength": 1 },
    "dispatch_fingerprint": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "generated_at": { "type": "string", "format": "date-time" },
    "status": { "enum": ["ready", "needs-triage"] },
    "workflow": { "enum": ["new-service", "product-intake", "runtime-assurance", "debugging", "infrastructure-change", "pipeline-change", "knowledge-ingestion", "support-escalation", "production-release", "rollback", "needs-triage"] },
    "inputs": { "type": "object" },
    "matched_routes": { "type": "array", "items": { "type": "string" } },
    "matched_risks": { "type": "array", "items": { "type": "object" } },
    "agents": {
      "type": "object",
      "required": ["primary", "reviewers", "support"],
      "properties": {
        "primary": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "reviewers": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "support": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "required_quality_gates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "required", "reason", "contributing_routes"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "required": { "const": true },
          "reason": { "type": "string", "minLength": 1 },
          "contributing_routes": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "ignored_quality_gates": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "gate_dispatch": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["gate_id", "status", "agents", "tasks", "artifacts"], "properties": { "gate_id": { "type": "string", "minLength": 1 }, "status": { "enum": ["required", "ignored"] }, "agents": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }, "tasks": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }, "artifacts": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } } } } },
    "human_gates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "required", "reason"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "required": { "const": true },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "knowledge_context": { "type": "object" }
  }
}

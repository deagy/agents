{
  "id": "generic",
  "version": "0.3.0",
  "gate_bindings": {
    "G1": {
      "contributions": {
        "intent": {
          "agents": ["product-intent-agent"],
          "tasks": ["capture-intent"],
          "artifacts": ["intent-record"]
        }
      }
    },
    "G2": {
      "contributions": {
        "requirements": {
          "agents": ["requirements-agent"],
          "tasks": ["baseline-requirements"],
          "artifacts": ["requirements-baseline"]
        }
      }
    },
    "G3": {
      "contributions": {
        "architecture-design": {
          "agents": ["cloud-architect"],
          "tasks": ["define-architecture"],
          "artifacts": ["architecture-record"]
        }
      }
    },
    "G4": {
      "contributions": {
        "governance-data": {
          "agents": ["governance-planner", "data-governance-engineer", "compliance-reviewer"],
          "tasks": ["assess-governance-and-data"],
          "artifacts": ["governance-data-record"]
        }
      }
    },
    "G5": {
      "contributions": {
        "security-crypto": {
          "agents": ["threat-modeler", "cryptographic-assurance-engineer", "security-reviewer"],
          "tasks": ["perform-security-and-crypto-review"],
          "artifacts": ["security-crypto-record"]
        }
      }
    },
    "G6": {
      "contributions": {
        "verification": {
          "agents": ["application-engineer", "test-engineer"],
          "tasks": ["implement-and-verify"],
          "artifacts": ["verification-record"]
        }
      }
    },
    "G7": {
      "contributions": {
        "evidence": {
          "agents": ["evidence-curator", "compliance-reviewer"],
          "tasks": ["curate-evidence"],
          "artifacts": ["evidence-index"]
        }
      }
    },
    "G8": {
      "contributions": {
        "release-readiness": {
          "agents": ["release-engineer"],
          "tasks": ["assess-release-readiness"],
          "artifacts": ["release-readiness-record"]
        }
      }
    },
    "G9": {
      "contributions": {
        "deployment-authorization": {
          "agents": [],
          "tasks": ["authorize-deployment"],
          "artifacts": ["deployment-authorization-record"]
        }
      }
    },
    "G10": {
      "contributions": {
        "runtime-conformance": {
          "agents": ["observability-sre"],
          "tasks": ["observe-runtime-conformance"],
          "artifacts": ["runtime-conformance-record"]
        }
      }
    }
  },
  "routing": [
    {
      "id": "new-service",
      "phrases": ["architecture", "service"],
      "agents": ["cloud-architect"],
      "reviewers": ["code-reviewer"],
      "support": [],
      "gates": ["G1", "G2", "G3"]
    }
  ]
}

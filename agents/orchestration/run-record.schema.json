{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agents/orchestration/run-record.schema.json",
  "title": "Authoritative agentic SDLC run record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version", "task_id", "recorded_at", "classification", "mode",
    "baseline_revision", "scope", "disposition", "intent_record_id",
    "requirements_baseline_id", "current_lifecycle_phase",
    "knowledge_retrieval", "sqs_impact_profile", "lifecycle_gates",
    "specialist_attestations", "re_entry_history"
  ],
  "properties": {
    "version": { "const": 2 },
    "task_id": { "$ref": "#/$defs/nonEmpty" },
    "recorded_at": { "type": "string", "format": "date-time" },
    "classification": { "$ref": "#/$defs/nonEmpty" },
    "mode": { "$ref": "#/$defs/nonEmpty" },
    "baseline_revision": { "$ref": "#/$defs/nonEmpty" },
    "scope": { "$ref": "#/$defs/nonEmpty" },
    "disposition": { "$ref": "#/$defs/nonEmpty" },
    "intent_record_id": { "type": ["string", "null"] },
    "requirements_baseline_id": { "type": ["string", "null"] },
    "current_lifecycle_phase": {
      "enum": ["intent", "requirements", "architecture", "governance-data", "security-crypto", "build", "verify", "evidence", "release-readiness", "deployment-authorization", "runtime-conformance", "feedback"]
    },
    "knowledge_retrieval": { "$ref": "#/$defs/knowledge" },
    "sqs_impact_profile": { "$ref": "#/$defs/sqsProfile" },
    "lifecycle_gates": {
      "type": "array", "minItems": 10, "maxItems": 10,
      "items": { "$ref": "#/$defs/lifecycleGate" },
      "allOf": [
        { "contains": { "properties": { "gate_id": { "const": "G1" } }, "required": ["gate_id"] } },
        { "contains": { "properties": { "gate_id": { "const": "G2" } }, "required": ["gate_id"] } },
        { "contains": { "properties": { "gate_id": { "const": "G3" } }, "required": ["gate_id"] } },
        { "contains": { "properties": { "gate_id": { "const": "G4" } }, "required": ["gate_id"] } },
        { "contains": { "properties": { "gate_id": { "const": "G5" } }, "required": ["gate_id"] } },
        { "contains": { "properties": { "gate_id": { "const": "G6" } }, "required": ["gate_id"] } },
        { "contains": { "properties": { "gate_id": { "const": "G7" } }, "required": ["gate_id"] } },
        { "contains": { "properties": { "gate_id": { "const": "G8" } }, "required": ["gate_id"] } },
        { "contains": { "properties": { "gate_id": { "const": "G9" } }, "required": ["gate_id"] } },
        { "contains": { "properties": { "gate_id": { "const": "G10" } }, "required": ["gate_id"] } }
      ]
    },
    "specialist_attestations": { "type": "array", "items": { "$ref": "#/$defs/specialistGate" } },
    "re_entry_history": { "type": "array", "items": { "$ref": "#/$defs/invalidation" } },
    "execution_summary": { "type": "object" }
  },
  "$defs": {
    "nonEmpty": { "type": "string", "minLength": 1 },
    "applicability": { "enum": ["applicable", "not-applicable", "unknown"] },
    "gateStatus": { "enum": ["pending", "ready", "approved", "request-changes", "needs-information", "blocked", "invalidated"] },
    "knowledge": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "reason", "query_ids", "evidence_refs", "influence"],
      "properties": {
        "status": { "enum": ["complete", "unavailable", "empty", "unauthorized", "not-applicable"] },
        "reason": { "type": ["string", "null"] },
        "query_ids": { "type": "array", "items": { "$ref": "#/$defs/nonEmpty" } },
        "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
        "influence": { "$ref": "#/$defs/nonEmpty" }
      }
    },
    "identity": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "role", "kind"],
      "properties": {
        "id": { "$ref": "#/$defs/nonEmpty" },
        "role": { "$ref": "#/$defs/nonEmpty" },
        "kind": { "enum": ["human", "agent", "service"] }
      }
    },
    "evidence": {
      "type": "object", "additionalProperties": false,
      "required": ["evidence_id", "uri", "hash_algorithm", "hash", "classification"],
      "properties": {
        "evidence_id": { "$ref": "#/$defs/nonEmpty" },
        "uri": { "$ref": "#/$defs/nonEmpty" },
        "hash_algorithm": { "$ref": "#/$defs/nonEmpty" },
        "hash": { "$ref": "#/$defs/nonEmpty" },
        "classification": { "$ref": "#/$defs/nonEmpty" }
      }
    },
    "artifactBinding": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_id", "revision", "digest"],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/nonEmpty" },
        "revision": { "$ref": "#/$defs/nonEmpty" },
        "digest": { "type": ["string", "null"] },
        "environment": { "type": ["string", "null"] }
      }
    },
    "finding": {
      "type": "object", "additionalProperties": false,
      "required": ["finding_id", "severity", "status", "owner"],
      "properties": {
        "finding_id": { "$ref": "#/$defs/nonEmpty" },
        "severity": { "enum": ["critical", "high", "medium", "low", "informational"] },
        "status": { "enum": ["open", "resolved", "accepted-exception"] },
        "owner": { "$ref": "#/$defs/nonEmpty" }
      }
    },
    "exception": {
      "type": "object", "additionalProperties": false,
      "required": ["exception_id", "finding_id", "justification", "compensating_controls", "owner", "approver", "expires_at", "remediation_plan"],
      "properties": {
        "exception_id": { "$ref": "#/$defs/nonEmpty" },
        "finding_id": { "$ref": "#/$defs/nonEmpty" },
        "justification": { "$ref": "#/$defs/nonEmpty" },
        "compensating_controls": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/nonEmpty" } },
        "owner": { "$ref": "#/$defs/identity" },
        "approver": { "$ref": "#/$defs/identity" },
        "expires_at": { "type": "string", "format": "date-time" },
        "remediation_plan": { "$ref": "#/$defs/nonEmpty" }
      }
    },
    "approval": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "approver", "decided_at", "evidence_refs"],
      "properties": {
        "status": { "enum": ["pending", "approved", "rejected", "not-required"] },
        "approver": { "anyOf": [{ "$ref": "#/$defs/identity" }, { "type": "null" }] },
        "decided_at": { "type": ["string", "null"], "format": "date-time" },
        "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/evidence" } }
      },
      "allOf": [
        { "if": { "properties": { "status": { "const": "approved" } } }, "then": { "properties": { "approver": { "$ref": "#/$defs/identity" }, "decided_at": { "type": "string", "format": "date-time" }, "evidence_refs": { "minItems": 1 } } } }
      ]
    },
    "authorityRequirement": {
      "type": "object", "additionalProperties": false,
      "required": ["authority_id", "authority_type", "role", "applicability", "rationale"],
      "properties": {
        "authority_id": { "$ref": "#/$defs/nonEmpty" },
        "authority_type": { "enum": ["independent-verifier", "human-approver"] },
        "role": { "$ref": "#/$defs/nonEmpty" },
        "applicability": { "$ref": "#/$defs/applicability" },
        "rationale": { "type": ["string", "null"] }
      },
      "allOf": [
        { "if": { "properties": { "applicability": { "const": "not-applicable" } }, "required": ["applicability"] }, "then": { "properties": { "rationale": { "$ref": "#/$defs/nonEmpty" } } } },
        { "if": { "properties": { "authority_id": { "const": "data-control-owner" } }, "required": ["authority_id"] }, "then": { "properties": { "authority_type": { "const": "human-approver" }, "role": { "const": "Data/Control Owner" } } } },
        { "if": { "properties": { "authority_id": { "const": "human-key-owner" } }, "required": ["authority_id"] }, "then": { "properties": { "authority_type": { "const": "human-approver" }, "role": { "const": "Human Key Owner" } } } },
        { "if": { "properties": { "authority_id": { "const": "uat-product-owner" } }, "required": ["authority_id"] }, "then": { "properties": { "authority_type": { "const": "human-approver" }, "role": { "const": "Product Owner" } } } },
        { "if": { "properties": { "authority_id": { "const": "implicated-security-lead" } }, "required": ["authority_id"] }, "then": { "properties": { "authority_type": { "const": "human-approver" }, "role": { "const": "Security Lead" } } } },
        { "if": { "properties": { "authority_id": { "const": "implicated-governance-lead" } }, "required": ["authority_id"] }, "then": { "properties": { "authority_type": { "const": "human-approver" }, "role": { "const": "Governance Lead" } } } }
      ]
    },
    "invalidation": {
      "type": "object", "additionalProperties": false,
      "required": ["invalidated_at", "reason", "earliest_gate", "invalidated_gate_ids", "superseding_artifact_id"],
      "properties": {
        "invalidated_at": { "type": "string", "format": "date-time" },
        "reason": { "$ref": "#/$defs/nonEmpty" },
        "earliest_gate": { "enum": ["G1", "G2", "G3", "G4", "G5", "G6", "G7", "G8", "G9", "G10"] },
        "invalidated_gate_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["G1", "G2", "G3", "G4", "G5", "G6", "G7", "G8", "G9", "G10"] } },
        "superseding_artifact_id": { "type": ["string", "null"] }
      }
    },
    "baseGate": {
      "type": "object",
      "required": ["tier", "gate_id", "name", "applicability", "applicability_rationale", "status", "artifact_bindings", "preparers", "independent_verifier", "independence_declaration", "authority_requirements", "human_approvals", "decided_at", "evidence_refs", "knowledge_status", "findings", "exceptions", "invalidation_history", "required_reentry_gate"],
      "properties": {
        "tier": { "enum": ["lifecycle", "specialist"] },
        "gate_id": { "$ref": "#/$defs/nonEmpty" },
        "name": { "$ref": "#/$defs/nonEmpty" },
        "applicability": { "$ref": "#/$defs/applicability" },
        "applicability_rationale": { "type": ["string", "null"] },
        "status": { "$ref": "#/$defs/gateStatus" },
        "artifact_bindings": { "type": "array", "items": { "$ref": "#/$defs/artifactBinding" } },
        "preparers": { "type": "array", "items": { "$ref": "#/$defs/identity" } },
        "independent_verifier": { "anyOf": [{ "$ref": "#/$defs/identity" }, { "type": "null" }] },
        "independence_declaration": {
          "type": "object", "additionalProperties": false,
          "required": ["verifier_confirmed_not_preparer", "verifier_made_material_correction"],
          "properties": {
            "verifier_confirmed_not_preparer": { "type": "boolean" },
            "verifier_made_material_correction": { "const": false }
          }
        },
        "authority_requirements": { "type": "array", "items": { "$ref": "#/$defs/authorityRequirement" } },
        "human_approvals": { "type": "array", "items": { "$ref": "#/$defs/approval" } },
        "decided_at": { "type": ["string", "null"], "format": "date-time" },
        "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
        "knowledge_status": { "enum": ["complete", "unavailable", "empty", "unauthorized", "not-applicable"] },
        "findings": { "type": "array", "items": { "$ref": "#/$defs/finding" } },
        "exceptions": { "type": "array", "items": { "$ref": "#/$defs/exception" } },
        "invalidation_history": { "type": "array", "items": { "$ref": "#/$defs/invalidation" } },
        "required_reentry_gate": { "type": ["string", "null"], "enum": [null, "G1", "G2", "G3", "G4", "G5", "G6", "G7", "G8", "G9", "G10"] }
      }
    },
    "lifecycleGate": {
      "allOf": [
        { "$ref": "#/$defs/baseGate" },
        { "properties": { "tier": { "const": "lifecycle" }, "gate_id": { "enum": ["G1", "G2", "G3", "G4", "G5", "G6", "G7", "G8", "G9", "G10"] } } }
      ],
      "unevaluatedProperties": false
    },
    "specialistGate": {
      "allOf": [
        { "$ref": "#/$defs/baseGate" },
        { "properties": { "tier": { "const": "specialist" } } }
      ],
      "unevaluatedProperties": false
    },
    "impactItem": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "applicability", "definition_reference", "rationale", "owner", "evidence_refs"],
      "properties": {
        "id": { "enum": ["platform-phase", "platform-component", "participant-digital-ecosystem-relevance", "digital-domain-impact", "governance-policy-impact", "trust-impact", "time-impact", "qkms-crypto-impact", "data-jurisdiction-impact", "meridian-impact", "ron-persistence-impact", "layer-0-impact", "evidence-requirement", "accreditation-relevance"] },
        "applicability": { "$ref": "#/$defs/applicability" },
        "definition_reference": { "type": ["string", "null"] },
        "rationale": { "type": ["string", "null"] },
        "owner": { "type": ["string", "null"] },
        "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/evidence" } }
      },
      "allOf": [
        { "if": { "properties": { "applicability": { "const": "applicable" } } }, "then": { "properties": { "definition_reference": { "$ref": "#/$defs/nonEmpty" }, "owner": { "$ref": "#/$defs/nonEmpty" } } } },
        { "if": { "properties": { "applicability": { "const": "not-applicable" } } }, "then": { "properties": { "rationale": { "$ref": "#/$defs/nonEmpty" }, "owner": { "$ref": "#/$defs/nonEmpty" } } } }
      ]
    },
    "bomItem": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "applicability", "definition_reference", "owner", "evidence_refs"],
      "properties": {
        "type": { "enum": ["SBOM", "CBOM", "QBOM", "AI-BOM", "Trust-BOM", "Time-BOM"] },
        "applicability": { "$ref": "#/$defs/applicability" },
        "definition_reference": { "type": ["string", "null"] },
        "owner": { "type": ["string", "null"] },
        "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/evidence" } }
      },
      "allOf": [
        { "if": { "properties": { "applicability": { "const": "applicable" } } }, "then": { "properties": { "definition_reference": { "$ref": "#/$defs/nonEmpty" }, "owner": { "$ref": "#/$defs/nonEmpty" } } } }
      ]
    },
    "sqsProfile": {
      "type": "object", "additionalProperties": false,
      "required": ["profile_id", "status", "impact_categories", "specialized_boms", "blocking_unknowns"],
      "properties": {
        "profile_id": { "$ref": "#/$defs/nonEmpty" },
        "status": { "enum": ["draft", "blocked", "complete"] },
        "impact_categories": {
          "type": "array", "minItems": 14, "maxItems": 14, "items": { "$ref": "#/$defs/impactItem" },
          "allOf": [
            { "contains": { "properties": { "id": { "const": "platform-phase" } }, "required": ["id"] } },
            { "contains": { "properties": { "id": { "const": "platform-component" } }, "required": ["id"] } },
            { "contains": { "properties": { "id": { "const": "participant-digital-ecosystem-relevance" } }, "required": ["id"] } },
            { "contains": { "properties": { "id": { "const": "digital-domain-impact" } }, "required": ["id"] } },
            { "contains": { "properties": { "id": { "const": "governance-policy-impact" } }, "required": ["id"] } },
            { "contains": { "properties": { "id": { "const": "trust-impact" } }, "required": ["id"] } },
            { "contains": { "properties": { "id": { "const": "time-impact" } }, "required": ["id"] } },
            { "contains": { "properties": { "id": { "const": "qkms-crypto-impact" } }, "required": ["id"] } },
            { "contains": { "properties": { "id": { "const": "data-jurisdiction-impact" } }, "required": ["id"] } },
            { "contains": { "properties": { "id": { "const": "meridian-impact" } }, "required": ["id"] } },
            { "contains": { "properties": { "id": { "const": "ron-persistence-impact" } }, "required": ["id"] } },
            { "contains": { "properties": { "id": { "const": "layer-0-impact" } }, "required": ["id"] } },
            { "contains": { "properties": { "id": { "const": "evidence-requirement" } }, "required": ["id"] } },
            { "contains": { "properties": { "id": { "const": "accreditation-relevance" } }, "required": ["id"] } }
          ]
        },
        "specialized_boms": {
          "type": "array", "minItems": 6, "maxItems": 6, "items": { "$ref": "#/$defs/bomItem" },
          "allOf": [
            { "contains": { "properties": { "type": { "const": "SBOM" } }, "required": ["type"] } },
            { "contains": { "properties": { "type": { "const": "CBOM" } }, "required": ["type"] } },
            { "contains": { "properties": { "type": { "const": "QBOM" } }, "required": ["type"] } },
            { "contains": { "properties": { "type": { "const": "AI-BOM" } }, "required": ["type"] } },
            { "contains": { "properties": { "type": { "const": "Trust-BOM" } }, "required": ["type"] } },
            { "contains": { "properties": { "type": { "const": "Time-BOM" } }, "required": ["type"] } }
          ]
        },
        "blocking_unknowns": { "type": "array", "items": { "$ref": "#/$defs/nonEmpty" } }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "complete" } }, "required": ["status"] },
          "then": {
            "properties": {
              "blocking_unknowns": { "maxItems": 0 },
              "impact_categories": { "not": { "contains": { "properties": { "applicability": { "const": "unknown" } }, "required": ["applicability"] } } },
              "specialized_boms": { "not": { "contains": { "properties": { "applicability": { "const": "unknown" } }, "required": ["applicability"] } } }
            }
          }
        }
      ]
    }
  }
}

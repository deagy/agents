{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/agent-context.schema.json",
  "title": "Agent Knowledge Context",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "task_id", "agent", "query_id", "retrieved_at", "classification", "trust", "requirements", "results"],
  "properties": {
    "schema_version": { "const": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "agent": { "type": "string", "minLength": 1 },
    "query_id": { "type": "string", "pattern": "^[a-f0-9]{16}$" },
    "retrieved_at": { "type": "string", "format": "date-time" },
    "classification": { "enum": ["public", "internal", "confidential", "restricted"] },
    "source_filter": { "type": ["string", "null"] },
    "trust": { "const": "untrusted_reference" },
    "requirements": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["score", "citation", "role", "content", "untrusted_instruction_risk"]
      }
    }
  }
}
